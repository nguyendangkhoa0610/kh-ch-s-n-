// Prisma Schema — Trầm Hương Eco-Resort
// Phase 1: Core models (SQLite for local dev — switch to postgresql when deploying)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MODELS ====================

model User {
  id           String  @id @default(cuid())
  email        String? @unique
  phone        String? @unique
  name         String
  avatar       String?
  role         String  @default("GUEST") // GUEST | STAFF | MANAGER | ADMIN
  passwordHash String?
  pushToken    String?

  ecoPoints           Int      @default(0)
  completedChallenges String[] @default([])

  bookings            Booking[]
  shifts              Shift[]
  alerts              SOSAlert[]
  sentMessages        Message[]          @relation("SentMessages")
  incidentReports     IncidentReport[]   @relation("IncidentReports")
  housekeepingTasks   HousekeepingTask[] @relation("AssignedTasks")
  maintenanceReports  MaintenanceRequest[]
  wishlist            Wishlist[]
  foodOrders          FoodOrder[]
  ecoRedemptions      EcoRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RoomType {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  tagline     String  @default("")
  description String
  basePrice   Int
  capacity    Int
  size        Int
  bedType     String  @default("")
  view        String  @default("")
  amenities   String  // JSON array stored as string
  images      String  // JSON array stored as string
  badge       String?

  rooms          Room[]
  wishlistItems  Wishlist[]
  seasonalPrices SeasonalPrice[]

  @@map("room_types")
}

model Room {
  id         String @id @default(cuid())
  number     String @unique
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  status     String   @default("AVAILABLE") // AVAILABLE | OCCUPIED | MAINTENANCE
  floor      Int      @default(1)

  bookings            Booking[]
  housekeepingTasks   HousekeepingTask[]
  maintenanceRequests MaintenanceRequest[]

  @@map("rooms")
}

model Booking {
  id     String @id @default(cuid())
  code   String @unique
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roomId String?
  room   Room?  @relation(fields: [roomId], references: [id])

  checkIn  DateTime
  checkOut DateTime
  guests   Int

  totalAmount    Int
  promoCode      String?
  discountAmount Int     @default(0)
  packageType    String?
  status         String  @default("PENDING") // PENDING | CONFIRMED | CHECKED_IN | COMPLETED | CANCELLED

  // Khai báo tạm trú
  idNumber    String?
  idType      String? // CCCD | CMND | PASSPORT
  nationality String? @default("VN")
  dateOfBirth String? // DD/MM/YYYY
  address     String?

  payment         Payment?
  activities      ActivityBooking[]
  digitalKey      DigitalKey?
  foodOrders      FoodOrder[]
  review          BookingReview?
  serviceRequests ServiceRequest[]
  spaBookings     SpaBooking[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model Activity {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String
  price       Int
  duration    Int
  maxSlots    Int
  category    String  // water | land | wellness | food
  images      String  // JSON array stored as string
  isActive    Boolean @default(true)

  schedules ActivitySchedule[]

  @@map("activities")
}

model ActivitySchedule {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id])
  startTime   DateTime
  bookedSlots Int      @default(0)

  bookings ActivityBooking[]

  @@map("activity_schedules")
}

model ActivityBooking {
  id         String           @id @default(cuid())
  bookingId  String
  booking    Booking          @relation(fields: [bookingId], references: [id])
  scheduleId String
  schedule   ActivitySchedule @relation(fields: [scheduleId], references: [id])
  guests     Int

  @@map("activity_bookings")
}

model Payment {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  booking       Booking   @relation(fields: [bookingId], references: [id])
  amount        Int
  method        String    // VNPAY | MOMO | ZALOPAY | CASH
  status        String    @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED
  transactionId String?
  paidAt        DateTime?

  @@map("payments")
}

model DigitalKey {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  booking    Booking   @relation(fields: [bookingId], references: [id])
  token      String    @unique
  qrCode     String
  validFrom  DateTime
  validUntil DateTime
  revokedAt  DateTime?

  unlockLogs UnlockLog[]

  @@map("digital_keys")
}

model UnlockLog {
  id         String     @id @default(cuid())
  keyId      String
  key        DigitalKey @relation(fields: [keyId], references: [id])
  unlockedAt DateTime   @default(now())
  doorId     String

  @@map("unlock_logs")
}

model SOSAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String    // SOS | INCIDENT | REQUEST
  location    String    // JSON: { lat, lng, area }
  message     String?
  status      String    @default("NEW") // NEW | RESPONDING | RESOLVED
  respondedBy String?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("sos_alerts")
}

model Shift {
  id        String   @id @default(cuid())
  staffId   String
  staff     User     @relation(fields: [staffId], references: [id])
  startTime DateTime
  endTime   DateTime
  area      String
  notes     String?

  @@map("shifts")
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  team      String   // "all" | "reception" | "beach" | "kitchen" | "housekeeping"
  content   String
  createdAt DateTime @default(now())

  @@map("messages")
}

model IncidentReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("IncidentReports", fields: [reporterId], references: [id])
  area        String
  description String
  photoUrl    String?
  severity    String   @default("LOW") // LOW | MEDIUM | HIGH
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  createdAt   DateTime @default(now())

  @@map("incident_reports")
}

// Đánh giá của khách (submit → chờ admin duyệt → hiện trên web)
model Review {
  id        String   @id @default(cuid())
  name      String
  location  String?
  room      String?
  rating    Int      @default(5)   // 1-5
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reviews")
}

// Mã giảm giá
model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int       // 0-100
  maxUses         Int       @default(100)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())

  @@map("promo_codes")
}

// Key-value store cho các cài đặt vận hành (crowd level, notice, v.v.)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String   @default("system")

  @@map("settings")
}

// Housekeeping — dọn phòng
model HousekeepingTask {
  id           String    @id @default(cuid())
  roomId       String
  room         Room      @relation(fields: [roomId], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  type         String    @default("CHECKOUT") // CHECKOUT | STAYOVER | INSPECTION | DEEP_CLEAN
  status       String    @default("PENDING")  // PENDING | IN_PROGRESS | DONE | SKIPPED
  priority     String    @default("NORMAL")   // LOW | NORMAL | HIGH | URGENT
  notes        String?
  startedAt    DateTime?
  completedAt  DateTime?
  scheduledFor DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@map("housekeeping_tasks")
}

// Maintenance — báo sự cố phòng
model MaintenanceRequest {
  id          String    @id @default(cuid())
  roomId      String
  room        Room      @relation(fields: [roomId], references: [id])
  reporterId  String
  reporter    User      @relation(fields: [reporterId], references: [id])
  title       String
  description String
  photoUrl    String?
  category    String    @default("OTHER") // PLUMBING | ELECTRICAL | AC | FURNITURE | CLEANING | OTHER
  priority    String    @default("NORMAL")
  status      String    @default("OPEN")  // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("maintenance_requests")
}

// Menu nhà hàng
model MenuItem {
  id          String      @id @default(cuid())
  name        String
  nameEn      String?
  description String?
  category    String      // BREAKFAST | LUNCH | DINNER | DRINKS | SNACKS
  price       Int
  image       String?
  isActive    Boolean     @default(true)
  isVeg       Boolean     @default(false)
  sortOrder   Int         @default(0)
  orderItems  FoodOrderItem[]

  @@map("menu_items")
}

// Đặt món
model FoodOrder {
  id         String          @id @default(cuid())
  bookingId  String
  booking    Booking         @relation(fields: [bookingId], references: [id])
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  status     String          @default("PENDING") // PENDING | CONFIRMED | PREPARING | DELIVERED | CANCELLED
  totalAmount Int
  notes      String?
  deliveryTime DateTime?
  items      FoodOrderItem[]
  createdAt  DateTime        @default(now())

  @@map("food_orders")
}

model FoodOrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      FoodOrder @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Int
  notes      String?

  @@map("food_order_items")
}

// Gift voucher
model GiftVoucher {
  id          String    @id @default(cuid())
  code        String    @unique
  value       Int       // VND
  message     String?
  fromName    String
  fromEmail   String
  toName      String
  toEmail     String
  expiresAt   DateTime
  usedAt      DateTime?
  usedByBooking String?
  status      String    @default("ACTIVE") // ACTIVE | USED | EXPIRED
  paymentId   String?
  createdAt   DateTime  @default(now())

  @@map("gift_vouchers")
}

// Wishlist — phòng yêu thích
model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, roomTypeId])
  @@map("wishlists")
}

// Seasonal / dynamic pricing
model SeasonalPrice {
  id         String   @id @default(cuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  name       String   // "Tết", "Hè 2025", etc.
  startDate  DateTime
  endDate    DateTime
  priceMultiplier Float  @default(1.0) // 1.5 = +50%
  fixedPrice Int?        // override hẳn nếu set
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("seasonal_prices")
}

// Live chat khách ↔ lễ tân (web widget)
model ChatSession {
  id          String        @id @default(cuid())
  visitorName String
  visitorEmail String?
  status      String        @default("OPEN") // OPEN | CLOSED
  createdAt   DateTime      @default(now())
  lastMessageAt DateTime    @default(now())
  messages    ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sender    String      // "visitor" | "staff"
  senderName String
  content   String
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}

// Tree info cho AR Discovery
model TreeInfo {
  id          String  @id @default(cuid())
  qrCode      String  @unique // mã QR gắn trên biển cây
  name        String
  scientificName String?
  age         Int?    // tuổi cây (năm)
  height      Float?  // chiều cao (m)
  description String
  ecoValue    String  // giá trị sinh thái
  story       String? // câu chuyện về cây
  imageUrl    String?
  location    String? // vị trí trong resort
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  @@map("tree_info")
}

// Feedback khách cho AI Concierge — dùng để train
model AiFeedback {
  id         String   @id @default(cuid())
  question   String
  aiAnswer   String
  isGood     Boolean  // true = 👍, false = 👎
  correction String?  // khách gõ "câu trả lời đúng nên là..."
  addedToKb  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("ai_feedback")
}

// Knowledge Base cho RAG — admin quản lý
model KnowledgeEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("FAQ") // FAQ | ROOMS | SERVICES | POLICY | DINING
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_entries")
}

// Yêu cầu dịch vụ từ AI Concierge (dọn phòng, spa, xe, v.v.)
model ServiceRequest {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  type      String   // HOUSEKEEPING | SPA | TRANSPORT | ROOM_SERVICE | OTHER
  details   String?  // mô tả thêm từ khách
  status    String   @default("PENDING") // PENDING | IN_PROGRESS | DONE | CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_requests")
}

// Spa booking — đặt dịch vụ spa qua app mobile
model SpaBooking {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  service   String   // MASSAGE_TRAM_HUONG | FACIAL | COUPLE_SPA | SAUNA
  date      String   // YYYY-MM-DD
  timeSlot  String   // "09:00"
  guests    Int      @default(1)
  price     Int
  status    String   @default("PENDING") // PENDING | CONFIRMED | DONE | CANCELLED
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("spa_bookings")
}

// Eco rewards — phần thưởng có thể đổi bằng eco-points
model EcoReward {
  id          String   @id @default(cuid())
  title       String
  description String?
  pointCost   Int
  type        String   // DISCOUNT | ACTIVITY | VOUCHER | UPGRADE
  value       Int      // VND hoặc % tùy type
  isActive    Boolean  @default(true)
  stock       Int      @default(-1) // -1 = không giới hạn
  redemptions EcoRedemption[]
  createdAt   DateTime @default(now())

  @@map("eco_rewards")
}

// Eco redemptions — lịch sử đổi điểm của khách
model EcoRedemption {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  rewardId   String
  reward     EcoReward @relation(fields: [rewardId], references: [id])
  pointsUsed Int
  status     String    @default("ACTIVE") // ACTIVE | USED | EXPIRED
  code       String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@map("eco_redemptions")
}

// Rating sau check-out (mobile)
model BookingReview {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  overallRating Int     // 1-5
  cleanlinessRating Int @default(5)
  serviceRating    Int  @default(5)
  locationRating   Int  @default(5)
  comment      String?
  photos       String[] @default([])
  createdAt    DateTime @default(now())

  @@map("booking_reviews")
}
