# ─── Database ─────────────────────────────────────────────
# Dev: SQLite local | Production: PostgreSQL (Railway / Supabase)
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/tram_huong"

# ─── Auth ─────────────────────────────────────────────────
# Tạo key ngẫu nhiên: openssl rand -hex 32
AUTH_SECRET="change-this-to-a-random-64-char-string"

# ─── AI (Anthropic) ───────────────────────────────────────
# Dùng cho: AI Planner (/lap-lich), AI Concierge (mobile)
# Đăng ký: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── VNPay ────────────────────────────────────────────────
# Đăng ký sandbox: https://sandbox.vnpayment.vn/devreg/
# Production TMN_CODE và HASH_SECRET lấy từ VNPay merchant portal
VNPAY_TMN_CODE="DEMO"
VNPAY_HASH_SECRET="RAOEXHYVSDDIIENL"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# VNPAY_URL="https://pay.vnpay.vn/vpcpay.html"   ← production
VNPAY_RETURN_URL="http://localhost:3000/dat-phong/ket-qua"
# VNPAY_RETURN_URL="https://tramhuong-resort.vn/dat-phong/ket-qua"  ← production

# ─── Email (Resend) ───────────────────────────────────────
# Free: 3.000 email/tháng | Đăng ký: https://resend.com
RESEND_API_KEY="re_..."
RESEND_FROM="Trầm Hương Resort <no-reply@tramhuong-resort.vn>"
ADMIN_NOTIFY_EMAIL="admin@tramhuong-resort.vn"

# ─── URLs ─────────────────────────────────────────────────
SITE_URL="http://localhost:3000"
# SITE_URL="https://tramhuong-resort.vn"   ← production

# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
